#!/usr/bin/env bash

# Determine the file(s) to work on
if [ -n "$1" ]; then
    files=("$@")
else
    # No argument provided: work on every *.acsm in the current directory
    shopt -s nullglob
    files=(*.acsm)
    shopt -u nullglob

    if [ "${#files[@]}" -eq 0 ]; then
        echo "Error: No argument provided and no *.acsm found in current directory"
        exit 1
    fi
    echo "No argument provided, using ${#files[@]} *.acsm file(s) from current directory"
fi

status=0
for arg in "${files[@]}"; do
    echo "=== Processing $arg ==="

    # Download the ACSM data
    output=$(acsmdownloader "$arg" 2>&1)

    # Print the output so user can see what happened
    echo "$output"

    # Extract filename from the line starting with "Created "
    filename=$(echo "$output" | \grep "^Created " | sed 's/^Created //')

    # Check if we found a filename
    if [ -n "$filename" ]; then
        echo "Extracted filename: $filename"

        echo "Removing DRM from $filename"
        if adept_remove "$filename"; then
            rm "$arg"
        else
            status=1
        fi
    else
        echo "Error: Could not find a line starting with 'Created ' in the output"
        status=1
    fi
done

exit $status
