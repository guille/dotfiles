#!/usr/bin/env bash
# shellcheck disable=SC1091

set -e

source "$SCRIPT_BASE_DIR/common"

##
# node
##

module_name=node


add_if_not_there "ignore-scripts=true" "$HOME/.npmrc"
add_if_not_there "min-release-age=7" "$HOME/.npmrc"


mise use -g node@latest
mise use -g pnpm@latest

mise settings set npm.package_manager pnpm

mise x -- pnpm config set minimumReleaseAge 10080 # 1 week
mise x -- pnpm config set blockExoticSubdeps true
mise x -- pnpm config set trustPolicy no-downgrade

infoprint "[$module_name] installing packages..."
mise use -g npm:dockerfile-language-server-nodejs
mise use -g npm:typescript
mise use -g npm:typescript-language-server
mise use -g npm:yaml-language-server

if is_personal_or_hybrid; then
	mise use -g npm:svelte-language-server
fi
if is_work_or_hybrid; then
	mise use -g npm:@bufbuild/buf
	mise use -g npm:graphql-language-service-cli
fi
