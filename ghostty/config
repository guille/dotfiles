# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.
#
# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.

# # Empty values are used to reset config keys to default.
# key =

##
# Font
font-family = 0xProto Nerd Font
font-size = 12

##
# Colours
background = #2c2c2c
foreground = #e1e1e1
cursor-color = #45b7cf
selection-foreground = #ffffff
selection-background = #586e75

# Base16-London Tube
palette = 0=#231f20
palette = 1=#ee2e24
palette = 2=#00853e
palette = 3=#ffd204
palette = 4=#009ddc
palette = 5=#98005d
palette = 6=#85cebc
palette = 7=#d9d8d8
palette = 8=#737171
palette = 9=#ee2e24
palette = 10=#00853e
palette = 11=#ffd204
palette = 12=#009ddc
palette = 13=#98005d
palette = 14=#85cebc
palette = 15=#ffffff

##
# Settings
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 10s
resize-overlay = never
shell-integration-features = no-cursor
split-inherit-working-directory = true
tab-inherit-working-directory = true
window-inherit-working-directory = false

##
# Keybinds
# Splits
keybind = ctrl+s>right=new_split:right
keybind = ctrl+s>down=new_split:down
keybind = ctrl+s>left=new_split:left
keybind = ctrl+s>up=new_split:up
keybind = ctrl+s>enter=toggle_split_zoom

keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:up
keybind = ctrl+shift+down=goto_split:down

keybind = ctrl+shift+page_down=move_tab:1
keybind = ctrl+shift+page_up=move_tab:-1

# mistypes
keybind = shift+enter=text:\x1b[27;2;13~

keybind = global:super+grave_accent=toggle_quick_terminal

config-file = ?config-macos
config-file = ?config-linux
