{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit(*)",
      "Glob",
      "Grep",
      "Read(*)",
      "Bash(bundle exec rspec *)",
      "Bash(bundle exec rubocop *)",
      "Bash(dart analyze *)",
      "Bash(flutter analyze *)",
      "Bash(flutter gen-l10n *)",
      "Bash(flutter test *)",
      "Bash(go build *)",
      "Bash(go env *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(gotestsum *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(mise run *)",
      "Bash(mix *)",
      "Bash(mkdir *)",
      "Bash(rg *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(true)",
      "Bash(uv run pytest *)",
      "Bash(wc *)"
    ],
    "deny": [
      "NotebookEdit",
      "WebSearch",
      "mcp__*",
      "Edit(mise.toml)",
      "Edit(mise.local.toml)",
      "Read(*.env*)",
      "Bash(rm *)"
    ],
    "additionalDirectories": [
      "~/go/pkg/mod",
      "~/work"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "trash=\"${NNN_TRASH:-gio trash}\"; jq --arg trash \"$trash\" 'if (.tool_input.command | test(\"^rm\\\\s+[^-]\")) then {hookSpecificOutput: {hookEventName: \"PreToolUse\", updatedInput: {command: (.tool_input.command | sub(\"^rm\"; $trash))}}} else {} end'",
            "if": "Bash(rm *)"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Fucking around",
      "Finding out"
    ]
  },
  "autoUpdatesChannel": "stable",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto"
}
