{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "NotebookEdit",
      "WebSearch",
      "mcp__*"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 1
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Fucking around",
      "Finding out"
    ]
  },
  "autoUpdatesChannel": "stable",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto"
}
