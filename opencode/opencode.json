{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "default_agent": "plan",
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "edit": {
      "*": "allow",
      "mise.toml": "deny",
      "mise.local.toml": "deny",
    },
    "glob": "allow",
    "list": "allow",
    "grep": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "read": {
      "*": "allow",
      "*.env*": "deny"
    },
    "task": {
      "*": "ask",
      "explore": "allow"
    },
    "webfetch": "ask",
    "bash": {
      "*": "ask",
      "bundle exec rspec *": "allow",
      "bundle exec rubocop *": "allow",
      "dart analyze *": "allow",
      "flutter analyze *": "allow",
      "flutter test *": "allow",
      "go build *": "allow",
      "go env *": "allow",
      "go test *": "allow",
      "go vet *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "mise run *": "allow",
      "mkdir *": "allow",
      "rg *": "allow",
      "rm *": "deny",
      "sort": "allow",
      "tail *": "allow",
      "wc *": "allow",
    },
    "external_directory": {
      "*": "deny",
      "~/go/pkg/mod/**": "allow",
      "~/work/**": "allow",
      "/tmp/**": "ask"
    },
  },
  "enabled_providers": [
    "github-copilot",
    "opencode",
  ],
  "experimental": {
    "continue_loop_on_deny": true
  },
  "lsp": {
    "yaml-ls": {
      "command": [
        "yaml-language-server",
        "--stdio"
      ],
      "extensions": [
        ".yaml",
        ".yml",
        ".sublime-syntax"
      ]
    },
    "kotlin-ls": {
      "disabled": true
    },
    "lua-ls": {
      "disabled": true
    },
  },
}
