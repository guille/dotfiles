{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "default_agent": "plan",
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "edit": "allow",
    "glob": "allow",
    "list": "allow",
    "grep": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "read": {
      "*": "allow",
      "*.env*": "deny"
    },
    "task": {
      "*": "ask",
      "explore": "allow"
    },
    "webfetch": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "bundle exec rspec *": "allow",
      "bundle exec rubocop *": "allow",
      "go build *": "allow",
      "go test *": "allow",
      "go vet *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "mkdir *": "allow",
      "tail *": "allow",
      "rm *": "deny",
      "sort": "allow",
    },
    "external_directory": {
      "*": "deny",
      "~/go/pkg/mod/**": "allow",
      "~/work/**": "allow",
      "/tmp/**": "ask"
    },
  },
  "enabled_providers": [
    "github-copilot",
    "opencode",
  ],
}
