{
    "layer": "top",
    "position": "bottom",
    "height": 30,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": [
        "mpd"
    ],
    "modules-right": [
        "battery",
        "disk",
        "disk#disk2",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "cpu",
        "custom/separator",
        "memory",
        "custom/separator",
        "custom/vpn",
        "network",
        "custom/separator",
        "clock",
        "custom/separator",
        "custom/packages",
        "idle_inhibitor",
        "custom/dunst",
        "custom/separator",
        "tray",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "all-outputs": true,
        "format": "{name}{icon}",
        "format-icons": {
            "1": "",
            "default": ""
        }
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "mpd": {
        "format": "<span color=\"#ffd204\">≤░ΟΙ</span> {stateIcon}",
        "format-disconnected": "≤░ΟΛ",
        "format-stopped": "<span color=\"#ffd204\">≤░ΟΙ</span> Stopped",
        "unknown-tag": "N/A",
        "interval": 5,
        "state-icons": {
            // Swapped so it's clearer that clicking changes it
            "paused": "≤░ΡΛ",
            "playing": "≤░Πν"
        },
        "on-click": "mpc toggle",
        "on-click-right": "mpc next",
        "tooltip": "false"
    },
    "tray": {},
    "clock": {
        "interval": 5,
        "tooltip": false,
        "format": "<span color=\"#ffd204\">≤░ξΦ</span>  {:%d/%m %H:%M}",
        "format-alt": "<span color=\"#ffd204\">≤░ξΦ</span>  {:%a %d/%m %H:%M:%S}"
    },
    "cpu": {
        "format": "<span color=\"#ffd204\">CPU</span> {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "<span color=\"#ffd204\">RAM</span> {}%"
    },
    "backlight": {
        "format": "<span color=\"#ffd204\">{icon}</span> {percent}%",
        "format-icons": [
            "ΌΟΞ",
            "ΌΠΥ",
            "ΌΠΣ",
            "ΌΠΠ",
            "ΌΠΟ",
            "ΌΠΞ",
            "ΌΠΛ",
            "ΌΠΙ",
            "ΌΟδ"
        ]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "<span color=\"#ffd204\">{icon}</span> {capacity}%",
        "format-full": "<span color=\"#ffd204\">{icon}</span> {capacity}%",
        "format-plugged": "<span color=\"#ffd204\">ΎΘο</span>  {capacity}%",
        "format-alt": "<span color=\"#ffd204\">{icon}</span> {time}",
        "format-icons": [
            "ΎΚΕ",
            "ΎΚΔ",
            "ΎΚΓ",
            "ΎΚΒ",
            "ΎΚΑ"
        ]
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ΎΔπ",
            "performance": "ΎΔπ",
            "balanced": "ΎΚΟ",
            "power-saver": "ΎΒυ"
        }
    },
    "network": {
        "format-wifi": "<span color=\"#ffd204\">≤░Ψσ </span> {essid}",
        "format-ethernet": "<span color=\"#ffd204\">ΎΔΒ </span>{ipaddr}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "<span color=\"#ffd204\">≤░Ψς </span>  Disconnected"
    },
    "disk": {
        "interval": 30,
        "format": "<span color=\"#ffd204\">{path}</span> {percentage_used}% used",
        "path": "/"
    },
    "disk#disk2": {
        "interval": 30,
        "format": "<span color=\"#ffd204\">{path}</span> {percentage_used}% used",
        "path": "/home/guille"
    },
    "pulseaudio": {
        // Scrolling changes volume
        "format": "<span color=\"#ffd204\">{icon}</span>  {volume}%",
        "tooltip": false,
        "format-muted": "<span color=\"#959ca1\">≤░ΨΒ</span>  {volume}%",
        "format-icons": {
            "default": [
                "≤░Χ┐",
                "≤░ΨΑ",
                "≤░Χ╛"
            ]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
    },
    "custom/packages": {
        "format": " <span color=\"#ffd204\">≤░μΘ </span>{} ",
        "tooltip": false,
        "hide-empty-text": true,
        "exec": "~/.config/waybar/scripts/packages.sh",
        "interval": "3600"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "<span color=\"#ffd204\">≤░Ζ╢ </span>",
            "deactivated": "≤░╛ς "
        }
    },
    "custom/vpn": {
        "format": " <span color=\"#ffd204\">{}</span>",
        "tooltip": false,
        "exec": "~/.config/waybar/scripts/vpn.sh",
        "restart-interval": 60
    },
    "custom/dunst": {
        "format": " <span color=\"#ffd204\">{}</span>",
        "tooltip": false,
        "exec": "~/.config/waybar/scripts/dunst.sh",
        "on-click": "dunstctl set-paused toggle",
        "restart-interval": 60
    },
    "custom/power": {
        "format": "<span color=\"#ee2e24\">ΎΑΣ </span>",
        "tooltip": false,
        "on-click": "~/mybin/rofi_logout.sh"
    },
    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    }
}
