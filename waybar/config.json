{
    "$schema": "https://raw.githubusercontent.com/Magniquick/waybar-config-schema/main/schema.json",
    "layer": "top",
    "position": "bottom",
    "height": 30,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": [
        "mpd"
    ],
    "modules-right": [
        "battery",
        // "disk",
        // "disk#disk2",
        // "custom/separator",
        "pulseaudio",
        "custom/separator",
        "cpu",
        "custom/separator",
        "memory",
        "custom/separator",
        "custom/vpn",
        "network",
        "custom/separator",
        "clock",
        "custom/separator",
        "custom/dnf",
        "custom/pacman",
        "idle_inhibitor",
        "custom/dunst",
        "custom/separator",
        "tray",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "all-outputs": true,
        "format": "{name}{icon}",
        "format-icons": {
            "1": "",
            "default": ""
        }
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "mpd": {
        "format": "<span color=\"#ffd204\">󰎈</span> {stateIcon}",
        "format-disconnected": "󰎊",
        "format-stopped": "<span color=\"#ffd204\">󰎈</span> Stopped",
        "unknown-tag": "N/A",
        "interval": 5,
        "state-icons": {
            // Swapped so it's clearer that clicking changes it
            "paused": "󰐊",
            "playing": "󰏤"
        },
        "on-click": "mpc toggle",
        "on-click-right": "mpc next",
        "tooltip": false
    },
    "tray": {},
    "clock": {
        "interval": 5,
        "tooltip": false,
        "format": "<span color=\"#ffd204\">󰥔</span>  {:%d/%m %H:%M}",
        "format-alt": "<span color=\"#ffd204\">󰥔</span>  {:%a %d/%m %H:%M:%S}"
    },
    "cpu": {
        "format": "<span color=\"#ffd204\">CPU</span> {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "<span color=\"#ffd204\">RAM</span> {}%"
    },
    "backlight": {
        "format": "<span color=\"#ffd204\">{icon}</span> {percent}%",
        "format-icons": [
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            "",
            ""
        ]
    },
    "battery": {
        "states": {
            "warning": 25,
            "critical": 15
        },
        "format": "<span color=\"#ffd204\">{icon}</span> {capacity}% <span color=\"#959ca1\">|</span>",
        "format-full": "<span color=\"#ffd204\"></span> {capacity}% <span color=\"#959ca1\">|</span>",
        "format-plugged": "<span color=\"#ffd204\">󰂄</span> {capacity}% <span color=\"#959ca1\">|</span>",
        "format-charging": "<span color=\"#ffd204\">󰂄</span> {capacity}% <span color=\"#959ca1\">|</span>",
        "format-alt": "<span color=\"#ffd204\">{icon}</span> {time} <span color=\"#959ca1\">|</span>",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ]
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "",
            "performance": "",
            "balanced": "",
            "power-saver": ""
        }
    },
    "network": {
        "format-wifi": "<span color=\"#ffd204\">󰖩 </span> {essid}",
        "format-ethernet": "<span color=\"#ffd204\"> </span>{ipaddr}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "<span color=\"#ffd204\">󰖪 </span>  Disconnected"
    },
    "disk": {
        "interval": 30,
        "format": "<span color=\"#ffd204\">{path}</span> {percentage_used}% used",
        "path": "/"
    },
    "disk#disk2": {
        "interval": 30,
        "format": "<span color=\"#ffd204\">{path}</span> {percentage_used}% used",
        "path": "/home/guille"
    },
    "pulseaudio": {
        // Scrolling changes volume
        "format": "<span color=\"#ffd204\">{icon}</span>  {volume}%",
        "tooltip": false,
        "format-muted": "<span color=\"#959ca1\">󰖁</span>  {volume}%",
        "format-icons": {
            "default": [
                "󰕿",
                "󰖀",
                "󰕾"
            ]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
    },
    "custom/dnf": {
        "format": " <span color=\"#ffd204\">󰣛 </span>{} ",
        "exec": "~/.config/waybar/scripts/dnf.sh",
        "exec-if": "[ \"$DOTFILES_DISTRO\" = \"Fedora\" ]",
        "tooltip": false,
        "hide-empty-text": true,
        "interval": 3600
    },
    "custom/pacman": {
        "format": " <span color=\"#ffd204\">󰣇 </span>{} ",
        "exec": "~/.config/waybar/scripts/pacman.sh",
        "exec-if": "[ \"$DOTFILES_DISTRO\" = \"Arch\" ]",
        "tooltip": false,
        "hide-empty-text": true,
        "interval": 3600
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "<span color=\"#ffd204\">󰅶 </span>",
            "deactivated": "󰾪 "
        }
    },
    "custom/vpn": {
        "format": " <span color=\"#ffd204\">{}</span>",
        "tooltip": false,
        "exec": "~/.config/waybar/scripts/vpn.sh",
        "restart-interval": 60
    },
    "custom/dunst": {
        "format": " <span color=\"#ffd204\">{}</span>",
        "tooltip": false,
        "exec": "~/.config/waybar/scripts/dunst.sh",
        "on-click": "dunstctl set-paused toggle",
        "restart-interval": 60
    },
    "custom/power": {
        "format": "<span color=\"#ee2e24\"> </span>",
        "tooltip": false,
        "on-click": "~/mybin/rofi_logout.sh"
    },
    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    }
}
